/**app.wxss**/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
}

/* teamify 样式 */
.my-paragraph {
  display: block;
  text-overflow: ellipsis;
  word-wrap: break-word;
}

.nav-title {
  font-weight: bolder !important;
  font-family: 'Times New Roman', Times, serif !important;
}

.my-avatar {
  width: 100px;
  height: 100px;
} 

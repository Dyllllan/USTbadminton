/* 页面整体可滚动，公开活动不阻挡我的活动 */
page {
  height: 100%;
  background: #e8f4f8;
}

.page-content {
  min-height: 100%;
  padding-bottom: 120rpx;
}

.my-activity-section {
  background: linear-gradient(180deg, #7ec8e3 0%, #a8d8ea 100%);
  padding-bottom: 24rpx;
}

.public-activity-section {
  background: #e8f4f8;
  padding-top: 8rpx;
}

.section-title {
  padding: 24rpx 32rpx 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #2d7a94;
}

.section-title-public {
  padding-top: 8rpx;
}

.my-activity-header {
  padding: 24rpx 32rpx 16rpx;
}

.section-title-my {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

.my-activity-scroll {
  padding: 0 24rpx 24rpx;
  width: 100%;
}

.my-activity-cards {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  gap: 24rpx;
  padding-right: 24rpx;
}

.my-activity-card {
  flex-shrink: 0;
  width: 280rpx;
  min-width: 280rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.my-activity-card.default-card {
  background: rgba(255, 255, 255, 0.7);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-role {
  font-size: 22rpx;
  color: #5a9fb8;
  font-weight: 500;
}

.card-date {
  font-size: 22rpx;
  color: #969799;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-detail {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 16rpx;
  margin-bottom: 12rpx;
}

.card-detail-item {
  font-size: 22rpx;
  color: #646566;
  background: rgba(126, 200, 227, 0.15);
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
}

.card-meta {
  font-size: 24rpx;
  color: #969799;
}

.login-tip {
  margin: 24rpx 32rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #5a9fb8;
  text-align: center;
}

.activity-list {
  margin: 0 32rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(126, 200, 227, 0.2);
}

.activity-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #ebedf0;
}

.activity-card:last-child {
  border-bottom: none;
}

.activity-info {
  flex: 1;
  min-width: 0;
}

.activity-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #323233;
  margin-bottom: 8rpx;
}

.activity-meta {
  font-size: 24rpx;
  color: #969799;
  margin-bottom: 8rpx;
}

.activity-type {
  margin-left: 16rpx;
}

.activity-detail {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 16rpx;
  margin-bottom: 8rpx;
}

.activity-detail-item {
  font-size: 24rpx;
  color: #646566;
  background: rgba(126, 200, 227, 0.15);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.activity-desc {
  font-size: 26rpx;
  color: #646566;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}
